{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [
    {
      "asDropdown": false,
      "icon": "apps",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Node Control",
      "tooltip": "",
      "type": "link",
      "url": "/d/grin-node-control/grin-node-control"
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Runtime Nodes",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "grin_runtime_nodes", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "type": "stat",
      "title": "Nodes Up",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(max by (node) (grin_node_up))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "type": "stat",
      "title": "Host RAM Used",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "type": "stat",
      "title": "Disk Free",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "type": "timeseries",
      "title": "Node Heights",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [{ "expr": "max by (node) (grin_node_height)", "legendFormat": "{{node}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "type": "timeseries",
      "title": "Container CPU",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [{ "expr": "max by (node_name) (grin_runtime_node_observation{metric=\"cpu_percent\"})", "legendFormat": "{{node_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "type": "timeseries",
      "title": "Container RAM",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [{ "expr": "max by (node_name) (grin_runtime_node_observation{metric=\"ram_bytes\"})", "legendFormat": "{{node_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "type": "timeseries",
      "title": "Peer Count",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [{ "expr": "max by (node) (grin_node_connections)", "legendFormat": "{{node}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "type": "table",
      "title": "Failure States",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "targets": [{ "expr": "max by (node_id, node_name, node_type, profile, status, failure_state) (grin_runtime_failure_state)", "format": "table", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "type": "table",
      "title": "Autosync State",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "targets": [{ "expr": "max by (node_id, node_name, node_type, profile, status) (grin_runtime_autosync_enabled)", "format": "table", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["grin", "runtime", "operations"],
  "templating": {
    "list": [
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(grin_node_up,node_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Node",
        "multi": true,
        "name": "node",
        "query": { "query": "label_values(grin_node_up,node_name)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Grin Runtime Operations",
  "uid": "grin-runtime-operations",
  "version": 2,
  "weekStart": ""
}
